# Base URL of the backend API (include /api suffix)
# Local development:
API_BASE_URL=http://localhost:5000/api

# Production (Vercel): set NUXT_PUBLIC_API_BASE (or API_BASE_URL) in the
# Vercel project's Environment Variables to your Railway backend URL, e.g.
# NUXT_PUBLIC_API_BASE=https://your-backend.up.railway.app/api
