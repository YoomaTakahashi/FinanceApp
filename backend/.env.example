PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
# Local development: discrete variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=finance_db

# Production (Railway): set MYSQL_URL (or DATABASE_URL) instead —
# it takes precedence over the DB_* variables above.
# MYSQL_URL=mysql://user:pass@host:3306/railway

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
# Single origin or comma-separated list (production + previews), no trailing slash
# FRONTEND_URL=https://your-app.vercel.app,https://your-app-git-main-you.vercel.app
FRONTEND_URL=http://localhost:3000

UPLOAD_MAX_SIZE=5242880
